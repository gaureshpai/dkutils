{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"paths": {
			"@package/*": ["./src/*"]
		},
		"strict": true,
		"declaration": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": ["src", "bin", "rslib.config.ts"]
}
