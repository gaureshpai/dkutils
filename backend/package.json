{
	"name": "dkutils-backend",
	"version": "2.0.2",
	"description": "A web-based platform offering a collection of utility tools, built with MERN stack (MongoDB, Express.js, React.js, Node.js) and TailwindCSS",
	"main": "index.js",
	"scripts": {
		"start": "node index.js",
		"dev": "nodemon index.js",
		"lint": "npx biome lint .",
		"lint:fix": "npx biome lint --write .",
		"migrate:total-usage-key": "node scripts/migrateTotalUsageKey.js",
		"test": "jest --testPathPatterns='__tests__' --forceExit"
	},
	"jest": {
		"testEnvironment": "node",
		"moduleNameMapper": {
			"^@backend/(.*)$": "<rootDir>/$1"
		}
	},
	"keywords": [
		"utility tools",
		"MERN stack",
		"TailwindCSS",
		"web development",
		"productivity",
		"open-source",
		"collaboration",
		"file conversion",
		"data management",
		"cloud storage",
		"document processing",
		"image editing",
		"PDF tools",
		"spreadsheet tools",
		"text manipulation",
		"code formatting",
		"API integration",
		"automation",
		"task management"
	],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@jimp/wasm-avif": "catalog:",
		"@jimp/wasm-webp": "catalog:",
		"@supabase/supabase-js": "^2.93.3",
		"archiver": "^7.0.1",
		"axios": "catalog:",
		"bcryptjs": "^3.0.3",
		"cheerio": "catalog:",
		"cors": "^2.8.6",
		"docx": "catalog:",
		"dotenv": "^17.2.3",
		"express": "^5.2.1",
		"express-rate-limit": "^8.2.1",
		"express-validator": "^7.3.1",
		"jimp": "catalog:",
		"jsonwebtoken": "^9.0.3",
		"module-alias": "^2.2.3",
		"mongoose": "^8.22.0",
		"multer": "^2.0.2",
		"pdf-lib": "catalog:",
		"pdf-merger-js": "^5.1.2",
		"pdf-parse": "catalog:",
		"pdfkit": "catalog:",
		"shortid": "^2.2.17",
		"xlsx": "catalog:",
		"xml2js": "^0.6.2"
	},
	"_moduleAliases": {
		"@backend": "."
	},
	"devDependencies": {
		"jest": "^30.3.0",
		"nodemon": "^3.1.11",
		"supertest": "^7.2.2"
	}
}